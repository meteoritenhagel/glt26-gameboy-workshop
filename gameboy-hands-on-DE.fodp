    <draw:frame presentation:style-name="pr23" draw:layer="layout" svg:width="25.2cm" svg:height="2.629cm" svg:x="1.3cm" svg:y="0cm" presentation:class="title" presentation:user-transformed="true">
     <draw:text-box>
      <text:p>Assembly</text:p>
     </draw:text-box>
    </draw:frame>
    <draw:frame presentation:style-name="pr25" draw:text-style-name="P117" draw:layer="layout" svg:width="25.37cm" svg:height="11.505cm" svg:x="1.3cm" svg:y="2.629cm" presentation:class="outline" presentation:user-transformed="true">
     <draw:text-box>
      <text:p><text:span text:style-name="T54">Wir simulieren Case-Statements:</text:span></text:p>
      <text:list text:style-name="L3">
       <text:list-item>
        <text:list>
         <text:list-header>
          <text:p><text:span text:style-name="T54"/></text:p>
         </text:list-header>
        </text:list>
        <text:p><text:span text:style-name="T55"/></text:p>
       </text:list-item>
      </text:list>
     </draw:text-box>
    </draw:frame>
    <draw:frame draw:style-name="gr140" draw:text-style-name="P120" draw:layer="layout" svg:width="18.415cm" svg:height="11.278cm" svg:x="3.81cm" svg:y="3.895cm">
     <draw:text-box>
      <text:p text:style-name="P118"><text:span text:style-name="T31">CaseStatement::</text:span></text:p>
      <text:p text:style-name="P118"><text:span text:style-name="T31"><text:tab/></text:span><text:span text:style-name="T30">ld</text:span><text:span text:style-name="T31"> a, [wVariable]</text:span></text:p>
      <text:p text:style-name="P118"><text:span text:style-name="T31"><text:tab/></text:span><text:span text:style-name="T30">cp</text:span><text:span text:style-name="T31"> 0 <text:s text:c="18"/></text:span><text:span text:style-name="T65">; in case [wVariable] == 0</text:span></text:p>
      <text:p text:style-name="P118"><text:span text:style-name="T31"><text:tab/></text:span><text:span text:style-name="T30">jr</text:span><text:span text:style-name="T31"> nz, </text:span><text:span text:style-name="T66">.notZero</text:span><text:span text:style-name="T67"> </text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T68"><text:tab/></text:span><text:span text:style-name="T33">call </text:span><text:span text:style-name="T69">VariableIsZero</text:span><text:span text:style-name="T34"> <text:s text:c="3"/></text:span><text:span text:style-name="T68">; call subroutine VariableIsZero</text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T68"><text:tab/></text:span><text:span text:style-name="T33">ret</text:span></text:p>
      <text:p text:style-name="P118"><text:span text:style-name="T70">.notZero</text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T32"><text:tab/></text:span><text:span text:style-name="T33">cp</text:span><text:span text:style-name="T34"> 1 <text:s text:c="18"/></text:span><text:span text:style-name="T65">; in case [wVariable] == 1</text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T71"><text:tab/></text:span><text:span text:style-name="T72">jr</text:span><text:span text:style-name="T73"> nz, </text:span><text:span text:style-name="T69">.notOne</text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T69"><text:tab/></text:span><text:span text:style-name="T33">call </text:span><text:span text:style-name="T69">VariableIsOne</text:span><text:span text:style-name="T34"> <text:s text:c="4"/></text:span><text:span text:style-name="T68">; call subroutine VariableIsOne</text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T68"><text:tab/></text:span><text:span text:style-name="T33">ret</text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T74">.notOne</text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T75"><text:tab/></text:span><text:span text:style-name="T33">cp</text:span><text:span text:style-name="T34"> 2 <text:s text:c="18"/></text:span><text:span text:style-name="T76">; in case [wVariable] == 2</text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T75"><text:tab/></text:span><text:span text:style-name="T33">jr</text:span><text:span text:style-name="T34"> nz, </text:span><text:span text:style-name="T69">.done</text:span><text:span text:style-name="T34"> <text:s text:c="7"/></text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T34"><text:tab/></text:span><text:span text:style-name="T33">call </text:span><text:span text:style-name="T69">VariableIsTwo</text:span><text:span text:style-name="T34"> <text:s text:c="4"/></text:span><text:span text:style-name="T68">; call subroutine VariableIsTwo</text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T74">.done</text:span></text:p>
      <text:p text:style-name="P118"><text:span text:style-name="T31"><text:tab/></text:span><text:span text:style-name="T30">ret</text:span></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T30"/></text:p>
      <text:p text:style-name="P119"><text:span text:style-name="T68">; ...</text:span></text:p>
     </draw:text-box>
    </draw:frame>
