    <draw:frame presentation:style-name="pr23" draw:layer="layout" svg:width="25.2cm" svg:height="2.629cm" svg:x="1.3cm" svg:y="0cm" presentation:class="title" presentation:user-transformed="true">
     <draw:text-box>
      <text:p>Assembly</text:p>
     </draw:text-box>
    </draw:frame>
    <draw:frame presentation:style-name="pr25" draw:text-style-name="P117" draw:layer="layout" svg:width="25.37cm" svg:height="11.505cm" svg:x="1.3cm" svg:y="2.629cm" presentation:class="outline" presentation:user-transformed="true">
     <draw:text-box>
      <text:p><text:span text:style-name="T54">Wir simulieren For-Statements:</text:span></text:p>
      <text:list text:style-name="L3">
       <text:list-item>
        <text:list>
         <text:list-header>
          <text:p><text:span text:style-name="T54"/></text:p>
         </text:list-header>
        </text:list>
        <text:p><text:span text:style-name="T55"/></text:p>
       </text:list-item>
      </text:list>
     </draw:text-box>
    </draw:frame>
    <draw:frame draw:style-name="gr135" draw:text-style-name="P111" draw:layer="layout" svg:width="18.415cm" svg:height="8.775cm" svg:x="3.81cm" svg:y="4.56cm">
     <draw:text-box>
      <text:p text:style-name="P109"><text:span text:style-name="T42">ForLoop::</text:span></text:p>
      <text:p text:style-name="P107"><text:span text:style-name="T59"><text:tab/></text:span><text:span text:style-name="T60">ld</text:span><text:span text:style-name="T61"> a, 10 <text:s text:c="7"/></text:span><text:span text:style-name="T62">; iterate 10 times</text:span></text:p>
      <text:p text:style-name="P107"><text:span text:style-name="T63">.loop</text:span></text:p>
      <text:p text:style-name="P109"><text:span text:style-name="T59"><text:tab/></text:span><text:span text:style-name="T60">and</text:span><text:span text:style-name="T59"> a <text:s text:c="11"/></text:span><text:span text:style-name="T62">; if </text:span><text:span text:style-name="T56">a &gt; 0</text:span></text:p>
      <text:p text:style-name="P109"><text:span text:style-name="T42"><text:tab/></text:span><text:span text:style-name="T43">ret</text:span><text:span text:style-name="T42"> z</text:span></text:p>
      <text:p text:style-name="P107"><text:span text:style-name="T56"><text:tab/></text:span><text:span text:style-name="T56">; do something</text:span></text:p>
      <text:p text:style-name="P107"><text:span text:style-name="T59"><text:tab/></text:span><text:span text:style-name="T60">jr </text:span><text:span text:style-name="T64">.loop</text:span></text:p>
     </draw:text-box>
    </draw:frame>
    <draw:frame draw:style-name="gr130" draw:text-style-name="P103" draw:layer="layout" svg:width="12.461cm" svg:height="1.407cm" svg:x="0.636cm" svg:y="13.971cm">
