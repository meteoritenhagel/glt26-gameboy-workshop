    <draw:frame presentation:style-name="pr25" draw:layer="layout" svg:width="25.37cm" svg:height="11.505cm" svg:x="1.3cm" svg:y="2.629cm" presentation:class="outline" presentation:user-transformed="true">
     <draw:text-box>
      <text:list text:style-name="L3">
       <text:list-header>
        <text:p text:style-name="P103"><text:span text:style-name="T21">Text Editor, z. B. </text:span><text:span text:style-name="T11">VSCodium </text:span><text:span text:style-name="T11">(MIT License)</text:span></text:p>
       </text:list-header>
       <text:list-item>
        <text:p><text:span text:style-name="T12">Installation (</text:span><text:span text:style-name="T12"><text:a xlink:href="https://vscodium.com/" xlink:type="simple">https://vscodium.com/</text:a></text:span><text:span text:style-name="T12">)</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p><text:span text:style-name="T12">Snap:</text:span><text:span text:style-name="T12"><text:line-break/></text:span><text:span text:style-name="T15">snap install codium --classic</text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p text:style-name="P93"><text:span text:style-name="T18">Aura:</text:span><text:span text:style-name="T18"><text:line-break/></text:span><text:span text:style-name="T22">sudo aura -A vscodium-bin</text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p><text:span text:style-name="T12">Flatpak:</text:span><text:span text:style-name="T12"><text:line-break/></text:span><text:span text:style-name="T15">flatpak install flathub </text:span><text:span text:style-name="T15">com.vscodium.codium</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
       <text:list-item>
        <text:p><text:span text:style-name="T16">RGBDS-Extension (MIT License): </text:span><text:span text:style-name="T16"><text:a xlink:href="https://github.com/DonaldHays/rgbds-vscode" xlink:type="simple">https://github.com/DonaldHays/rgbds-vscode</text:a></text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p><text:span text:style-name="T16">File &gt; Preferences &gt; Extensions</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
      </text:list>
     </draw:text-box>
    </draw:frame>
