   <draw:page draw:name="page5" draw:style-name="dp3" draw:master-page-name="Image" presentation:presentation-page-layout-name="AL2T1">
    <office:forms form:automatic-focus="false" form:apply-design-mode="false"/>
    <draw:frame presentation:style-name="pr23" draw:layer="layout" svg:width="25.2cm" svg:height="2.629cm" svg:x="1.3cm" svg:y="0cm" presentation:class="title" presentation:user-transformed="true">
     <draw:text-box>
      <text:p>Installation</text:p>
     </draw:text-box>
    </draw:frame>
    <draw:frame presentation:style-name="pr25" draw:layer="layout" svg:width="25.37cm" svg:height="11.505cm" svg:x="1.3cm" svg:y="2.629cm" presentation:class="outline" presentation:user-transformed="true">
     <draw:text-box>
      <text:list text:style-name="L3">
       <text:list-header>
        <text:p><text:span text:style-name="T11">RGBDS (MIT License): </text:span><text:span text:style-name="T11">Assembler/Linker</text:span></text:p>
       </text:list-header>
       <text:list-item>
        <text:p><text:span text:style-name="T12">Installation (</text:span><text:span text:style-name="T12"><text:a xlink:href="https://github.com/gbdev/rgbds" xlink:type="simple">https://github.com/gbdev/rgbds</text:a></text:span><text:span text:style-name="T12">)</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p><text:span text:style-name="T13">Download </text:span><text:span text:style-name="T14"><text:a xlink:href="https://github.com/gbdev/rgbds/releases/latest/download/rgbds-linux-x86_64.tar.xz" xlink:type="simple">https://github.com/gbdev/rgbds/releases/latest/download/rgbds-linux-x86_64.tar.xz</text:a></text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p><text:span text:style-name="T12">Extrahieren und </text:span><text:span text:style-name="T15">install.sh</text:span><text:span text:style-name="T12"> ausführen </text:span><text:span text:style-name="T12">(braucht z. B. </text:span><text:span text:style-name="T15">binutils</text:span><text:span text:style-name="T12">)</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
       <text:list-item>
        <text:p><text:span text:style-name="T16">Testen: Kommando &gt; </text:span><text:span text:style-name="T15">rgbasm -V</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p><text:span text:style-name="T17">Sollte zurückgeben: </text:span><text:span text:style-name="T15">rgbasm v1.0.1</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
      </text:list>
     </draw:text-box>
    </draw:frame>
    <draw:frame draw:style-name="gr118" draw:text-style-name="P32" draw:layer="layout" svg:width="7.62cm" svg:height="4.028cm" svg:x="19.685cm" svg:y="11.212cm">
