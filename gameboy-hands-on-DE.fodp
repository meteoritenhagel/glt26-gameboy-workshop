   <draw:page draw:name="page9" draw:style-name="dp3" draw:master-page-name="Image" presentation:presentation-page-layout-name="AL2T1">
    <office:forms form:automatic-focus="false" form:apply-design-mode="false"/>
    <draw:frame presentation:style-name="pr23" draw:layer="layout" svg:width="25.2cm" svg:height="2.629cm" svg:x="1.3cm" svg:y="0cm" presentation:class="title" presentation:user-transformed="true">
     <draw:text-box>
      <text:p>Installation</text:p>
     </draw:text-box>
    </draw:frame>
    <draw:frame presentation:style-name="pr25" draw:layer="layout" svg:width="25.37cm" svg:height="11.505cm" svg:x="1.3cm" svg:y="2.629cm" presentation:class="outline" presentation:user-transformed="true">
     <draw:text-box>
      <text:list text:style-name="L3">
       <text:list-header>
        <text:p><text:span text:style-name="T32">Gearboy (GPL-3.0 License): </text:span><text:span text:style-name="T32">Emulator/Debugger</text:span></text:p>
       </text:list-header>
       <text:list-item>
        <text:p><text:span text:style-name="T11">Installation</text:span><text:span text:style-name="T11"><text:line-break/></text:span><text:span text:style-name="T11">(</text:span><text:span text:style-name="T11"><text:a xlink:href="https://github.com/drhelius/Gearboy/" xlink:type="simple">https://github.com/drhelius/Gearboy/</text:a></text:span><text:span text:style-name="T11">)</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p><text:span text:style-name="T11">Snap:</text:span><text:span text:style-name="T11"><text:line-break/></text:span><text:span text:style-name="T12">snap install gearboy</text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p text:style-name="P93"><text:span text:style-name="T37">Aura:</text:span><text:span text:style-name="T37"><text:line-break/></text:span><text:span text:style-name="T37">siehe </text:span><text:span text:style-name="T37"><text:a xlink:href="https://aur.archlinux.org/packages/gearboy" xlink:type="simple">https://aur.archlinux.org/packages/gearboy</text:a></text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p><text:span text:style-name="T11">Direkter Download: </text:span><text:span text:style-name="T11"><text:a xlink:href="https://github.com/drhelius/Gearboy/releases/tag/3.7.5" xlink:type="simple">https://github.com/drhelius/Gearboy/releases/tag/3.7.5</text:a></text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
       <text:list-item>
        <text:p><text:span text:style-name="T35">Alternativ (free-to-use, aber </text:span><text:span text:style-name="T38">nicht quelloffen</text:span><text:span text:style-name="T35">): </text:span><text:span text:style-name="T35"><text:a xlink:href="https://emulicious.net/" xlink:type="simple">https://emulicious.net/</text:a></text:span></text:p>
       </text:list-item>
      </text:list>
     </draw:text-box>
    </draw:frame>
