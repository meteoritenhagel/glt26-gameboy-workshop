    <draw:frame presentation:style-name="pr25" draw:layer="layout" svg:width="25.37cm" svg:height="11.505cm" svg:x="1.3cm" svg:y="2.629cm" presentation:class="outline" presentation:user-transformed="true">
     <draw:text-box>
      <text:list text:style-name="L3">
       <text:list-header>
        <text:p text:style-name="P102"><text:span text:style-name="T40">Text Editor, z. B. </text:span><text:span text:style-name="T32">VSCodium (MIT License)</text:span></text:p>
       </text:list-header>
       <text:list-item>
        <text:p><text:span text:style-name="T11">Installation (</text:span><text:span text:style-name="T11"><text:a xlink:href="https://vscodium.com/" xlink:type="simple">https://vscodium.com/</text:a></text:span><text:span text:style-name="T11">)</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p><text:span text:style-name="T11">Snap:</text:span><text:span text:style-name="T11"><text:line-break/></text:span><text:span text:style-name="T12">snap install codium --classic</text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p text:style-name="P93"><text:span text:style-name="T37">Aura:</text:span><text:span text:style-name="T37"><text:line-break/></text:span><text:span text:style-name="T41">sudo aura -A vscodium-bin</text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p><text:span text:style-name="T11">Flatpak:</text:span><text:span text:style-name="T11"><text:line-break/></text:span><text:span text:style-name="T12">flatpak install flathub com.vscodium.codium</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
       <text:list-item>
        <text:p><text:span text:style-name="T35">RGBDS-Extension (MIT License): </text:span><text:span text:style-name="T35"><text:a xlink:href="https://github.com/DonaldHays/rgbds-vscode" xlink:type="simple">https://github.com/DonaldHays/rgbds-vscode</text:a></text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p><text:span text:style-name="T35">File &gt; Preferences &gt; Extensions</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
      </text:list>
     </draw:text-box>
