   <draw:page draw:name="page7" draw:style-name="dp3" draw:master-page-name="Image" presentation:presentation-page-layout-name="AL2T1">
    <office:forms form:automatic-focus="false" form:apply-design-mode="false"/>
    <draw:frame presentation:style-name="pr23" draw:layer="layout" svg:width="25.2cm" svg:height="2.629cm" svg:x="1.3cm" svg:y="0cm" presentation:class="title" presentation:user-transformed="true">
     <draw:text-box>
      <text:p>Installation</text:p>
     </draw:text-box>
    </draw:frame>
    <draw:frame presentation:style-name="pr25" draw:layer="layout" svg:width="25.37cm" svg:height="11.505cm" svg:x="1.13cm" svg:y="2.629cm" presentation:class="outline" presentation:user-transformed="true">
     <draw:text-box>
      <text:list text:style-name="L3">
       <text:list-header>
        <text:p><text:span text:style-name="T17">make: Build-Management</text:span></text:p>
       </text:list-header>
       <text:list-item>
        <text:p><text:span text:style-name="T18">Installation (</text:span><text:span text:style-name="T18"><text:a xlink:href="https://github.com/drhelius/Gearboy/" xlink:type="simple">https://github.com/drhelius/Gearboy/</text:a></text:span><text:span text:style-name="T18">)</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p><text:span text:style-name="T18">Apt:</text:span><text:span text:style-name="T18"><text:line-break/></text:span><text:span text:style-name="T21">sudo apt install make</text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p text:style-name="P93"><text:span text:style-name="T24">Arch: siehe </text:span><text:span text:style-name="T24"><text:a xlink:href="https://archlinux.org/packages/core/x86_64/make/" xlink:type="simple">https://archlinux.org/packages/core/x86_64/make/</text:a></text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p><text:span text:style-name="T18">Fedora: siehe </text:span><text:span text:style-name="T18"><text:a xlink:href="https://packages.fedoraproject.org/pkgs/make/make/index.html" xlink:type="simple">https://packages.fedoraproject.org/pkgs/make/make/index.html</text:a></text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
       <text:list-item>
        <text:p text:style-name="P104"><text:span text:style-name="T19">Testen: Kommando </text:span><text:span text:style-name="T21">make -v</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p text:style-name="P104"><text:span text:style-name="T19">Sollte zurückgeben: z. B. </text:span><text:span text:style-name="T26">GNU Make 4.3</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
      </text:list>
     </draw:text-box>
    </draw:frame>
    <draw:frame draw:style-name="gr130" draw:text-style-name="P103" draw:layer="layout" svg:width="12.461cm" svg:height="1.407cm" svg:x="0.636cm" svg:y="13.971cm">
     <draw:text-box>
      <text:p><text:page-number>&lt;number&gt;</text:page-number></text:p>
     </draw:text-box>
    </draw:frame>
    <presentation:notes draw:style-name="dp3">
     <office:forms form:automatic-focus="false" form:apply-design-mode="false"/>
     <draw:page-thumbnail draw:style-name="gr121" draw:layer="layout" svg:width="17cm" svg:height="9.56cm" svg:x="2cm" svg:y="2.5cm" draw:page-number="7" presentation:class="page"/>
     <draw:frame presentation:style-name="pr24" draw:text-style-name="P102" draw:layer="layout" svg:width="17cm" svg:height="14cm" svg:x="2cm" svg:y="13cm" presentation:class="notes" presentation:placeholder="true">
      <draw:text-box/>
     </draw:frame>
    </presentation:notes>
   </draw:page>
   <draw:page draw:name="page8" draw:style-name="dp3" draw:master-page-name="Image" presentation:presentation-page-layout-name="AL2T1">
    <office:forms form:automatic-focus="false" form:apply-design-mode="false"/>
    <draw:frame presentation:style-name="pr23" draw:layer="layout" svg:width="25.2cm" svg:height="2.629cm" svg:x="1.3cm" svg:y="0cm" presentation:class="title" presentation:user-transformed="true">
     <draw:text-box>
      <text:p>Installation</text:p>
     </draw:text-box>
    </draw:frame>
    <draw:frame presentation:style-name="pr25" draw:layer="layout" svg:width="25.37cm" svg:height="11.505cm" svg:x="1.3cm" svg:y="2.629cm" presentation:class="outline" presentation:user-transformed="true">
     <draw:text-box>
      <text:list text:style-name="L3">
       <text:list-header>
        <text:p text:style-name="P105"><text:span text:style-name="T27">Text Editor, z. B. </text:span><text:span text:style-name="T17">VSCodium (MIT License)</text:span></text:p>
       </text:list-header>
       <text:list-item>
        <text:p><text:span text:style-name="T18">Installation (</text:span><text:span text:style-name="T18"><text:a xlink:href="https://vscodium.com/" xlink:type="simple">https://vscodium.com/</text:a></text:span><text:span text:style-name="T18">)</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p><text:span text:style-name="T18">Snap:</text:span><text:span text:style-name="T18"><text:line-break/></text:span><text:span text:style-name="T21">snap install codium --classic</text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p text:style-name="P93"><text:span text:style-name="T24">Aura:</text:span><text:span text:style-name="T24"><text:line-break/></text:span><text:span text:style-name="T28">sudo aura -A vscodium-bin</text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p><text:span text:style-name="T18">Flatpak:</text:span><text:span text:style-name="T18"><text:line-break/></text:span><text:span text:style-name="T21">flatpak install flathub com.vscodium.codium</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
       <text:list-item>
        <text:p><text:span text:style-name="T22">RGBDS-Extension (MIT License): </text:span><text:span text:style-name="T22"><text:a xlink:href="https://github.com/DonaldHays/rgbds-vscode" xlink:type="simple">https://github.com/DonaldHays/rgbds-vscode</text:a></text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p><text:span text:style-name="T22">File &gt; Preferences &gt; Extensions</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
      </text:list>
     </draw:text-box>
    </draw:frame>
    <draw:frame draw:style-name="gr118" draw:text-style-name="P32" draw:layer="layout" svg:width="7.62cm" svg:height="4.028cm" svg:x="19.685cm" svg:y="11.212cm">
