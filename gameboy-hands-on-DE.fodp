   <draw:page draw:name="page7" draw:style-name="dp3" draw:master-page-name="Image" presentation:presentation-page-layout-name="AL2T1">
    <office:forms form:automatic-focus="false" form:apply-design-mode="false"/>
    <draw:frame presentation:style-name="pr23" draw:layer="layout" svg:width="25.2cm" svg:height="2.629cm" svg:x="1.3cm" svg:y="0cm" presentation:class="title" presentation:user-transformed="true">
     <draw:text-box>
      <text:p>Installation</text:p>
     </draw:text-box>
    </draw:frame>
    <draw:frame presentation:style-name="pr25" draw:layer="layout" svg:width="25.37cm" svg:height="11.505cm" svg:x="1.13cm" svg:y="2.629cm" presentation:class="outline" presentation:user-transformed="true">
     <draw:text-box>
      <text:list text:style-name="L3">
       <text:list-header>
        <text:p><text:span text:style-name="T11">make: Build-Management</text:span></text:p>
       </text:list-header>
       <text:list-item>
        <text:p><text:span text:style-name="T12">Installation (</text:span><text:span text:style-name="T12"><text:a xlink:href="https://github.com/drhelius/Gearboy/" xlink:type="simple">https://github.com/drhelius/Gearboy/</text:a></text:span><text:span text:style-name="T12">)</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p><text:span text:style-name="T12">Apt:</text:span><text:span text:style-name="T12"><text:line-break/></text:span><text:span text:style-name="T15">sudo apt install make</text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p text:style-name="P93"><text:span text:style-name="T18">Arch: siehe </text:span><text:span text:style-name="T18"><text:a xlink:href="https://archlinux.org/packages/core/x86_64/make/" xlink:type="simple">https://archlinux.org/packages/core/x86_64/make/</text:a></text:span></text:p>
         </text:list-item>
         <text:list-item>
          <text:p><text:span text:style-name="T12">Fedora: siehe </text:span><text:span text:style-name="T12"><text:a xlink:href="https://packages.fedoraproject.org/pkgs/make/make/index.html" xlink:type="simple">https://packages.fedoraproject.org/pkgs/make/make/index.html</text:a></text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
       <text:list-item>
        <text:p text:style-name="P102"><text:span text:style-name="T13">Testen: Kommando </text:span><text:span text:style-name="T15">make -v</text:span></text:p>
        <text:list>
         <text:list-item>
          <text:p text:style-name="P102"><text:span text:style-name="T13">Sollte zurückgeben: z. B. </text:span><text:span text:style-name="T20">GNU Make 4.3</text:span></text:p>
         </text:list-item>
        </text:list>
       </text:list-item>
      </text:list>
     </draw:text-box>
    </draw:frame>
